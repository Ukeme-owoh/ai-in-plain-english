---
import Base from './Base.astro';
import QuestionForm from '../components/QuestionForm.astro';

interface Props {
  title: string;
  description: string;
  week: number;
}

const { title, description, week } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={title} description={description}>
  <div class="slide-post">

    <div id="slides-wrapper" class="slides-wrapper">
      <slot />
      <section class="scene" data-scene="questions" data-animation="text-reveal">
        <div class="scene-layout">
          <div class="scene-text">
            <p class="week-tag animate-in">That's a wrap on Week {week}</p>
            <h2 class="animate-in">What did you want to know more about?</h2>
            <p class="animate-in">Every question helps shape what gets covered next.</p>
          </div>
          <div class="scene-visual" style="align-items:flex-start">
            <QuestionForm postTitle={title} />
          </div>
        </div>
      </section>
    </div>

    <nav class="slide-nav">
      <a href={base} class="nav-home">← All posts <span class="nav-author">by Ukeme Owoh</span></a>

      <div class="nav-center">
        <button id="prev-btn" class="nav-btn" aria-label="Previous scene">←</button>
        <div id="progress-dots" class="progress-dots"></div>
        <button id="next-btn" class="nav-btn" aria-label="Next scene">→</button>
      </div>

      <span class="nav-counter">
        <span id="scene-current">1</span> / <span id="scene-total">1</span>
      </span>
    </nav>

    <div class="click-hint" id="click-hint">Click anywhere to continue →</div>

  </div>
</Base>

<script>
  import { initSlides } from '../scripts/slide-engine.js';

  document.addEventListener('DOMContentLoaded', () => {
    initSlides();

    // Hide hint after first click
    const hint = document.getElementById('click-hint');
    document.addEventListener('click', () => {
      if (hint) hint.style.opacity = '0';
    }, { once: true });
  });
</script>
