---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Modern AI, explained without the PhD.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Ukeme Owoh" />
    <title>{title} — AI in Plain English</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
    <link rel="stylesheet" href={`${base}/styles/slides.css`} />
  </head>
  <body>
    <header>
      <nav>
        <a href={base}>AI in Plain English</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>One post a week. No PhD required.</p>
    </footer>
  </body>
</html>
