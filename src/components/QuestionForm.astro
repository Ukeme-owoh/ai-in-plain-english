---
interface Props {
  postTitle: string;
}
const { postTitle } = Astro.props;
---

<div class="question-form-wrap">
  <h3 class="qf-heading">Have a question?</h3>
  <p class="qf-sub">Ask anything about this post. Ukeme reads every question.</p>

  <form
    id="question-form"
    action="https://formspree.io/f/YOUR_FORM_ID"
    method="POST"
    class="qf-form"
  >
    <input type="hidden" name="post" value={postTitle} />

    <div class="qf-field">
      <label for="qf-name">Your name (optional)</label>
      <input type="text" id="qf-name" name="name" placeholder="Anonymous" autocomplete="off" />
    </div>

    <div class="qf-field">
      <label for="qf-question">Your question</label>
      <textarea id="qf-question" name="question" rows="3" placeholder="What confused you? What do you want to know more about?" required></textarea>
    </div>

    <button type="submit" class="qf-submit">Send question →</button>

    <p class="qf-success" id="qf-success" style="display:none">
      Question sent. Thank you.
    </p>
  </form>
</div>

<script>
  const form = document.getElementById('question-form') as HTMLFormElement | null;
  const success = document.getElementById('qf-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch(form.action, {
      method: 'POST',
      body: data,
      headers: { Accept: 'application/json' },
    });
    if (res.ok) {
      form.style.display = 'none';
      if (success) success.style.display = 'block';
    }
  });
</script>

<style>
  .question-form-wrap {
    width: 100%;
    max-width: 480px;
  }

  .qf-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e8e8e8;
    margin-bottom: 0.5rem;
  }

  .qf-sub {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 1.5rem;
  }

  .qf-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .qf-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .qf-field label {
    font-size: 0.78rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .qf-field input,
  .qf-field textarea {
    background: #111;
    border: 1px solid #222;
    border-radius: 6px;
    color: #e8e8e8;
    font-size: 0.95rem;
    padding: 0.6rem 0.85rem;
    font-family: inherit;
    resize: vertical;
    transition: border-color 0.2s;
    width: 100%;
  }

  .qf-field input:focus,
  .qf-field textarea:focus {
    outline: none;
    border-color: #6ee7b7;
  }

  .qf-submit {
    background: #6ee7b7;
    color: #0a0a0a;
    border: none;
    border-radius: 6px;
    padding: 0.65rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    align-self: flex-start;
    transition: opacity 0.2s;
  }

  .qf-submit:hover {
    opacity: 0.85;
  }

  .qf-success {
    color: #6ee7b7;
    font-size: 0.95rem;
    padding: 1rem 0;
  }
</style>
