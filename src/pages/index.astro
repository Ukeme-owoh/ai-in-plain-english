---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) => a.data.week - b.data.week);
const base = import.meta.env.BASE_URL;
---

<Base title="Home">
  <div class="home">

    <header class="home-header">
      <p class="home-eyebrow">AI in Plain English</p>
      <h1 class="home-title">Modern AI, explained.</h1>
      <p class="home-sub">
        One visual post a week. Transformers. Reasoning models. Agents. Evals.
        Written for curious people who want to understand AI without enrolling in a degree.
      </p>
      <p class="home-author">By <strong>Ukeme Owoh</strong></p>
    </header>

    <section class="post-grid">
      {posts.map((post) => (
        <a href={`${base}/posts/${post.slug}`} class="post-card">
          <span class="card-week">Week {post.data.week}</span>
          <h2 class="card-title">{post.data.title}</h2>
          <p class="card-desc">{post.data.description}</p>
          <span class="card-cta">Read →</span>
        </a>
      ))}

      {Array.from({ length: Math.max(0, 12 - posts.length) }).map((_, i) => (
        <div class="post-card post-card--coming">
          <span class="card-week">Week {posts.length + i + 1}</span>
          <h2 class="card-title coming-title">Coming soon</h2>
        </div>
      ))}
    </section>

  </div>
</Base>

<style>
  /* Let the home page fill the full viewport width */
  :global(main) {
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }

  .home {
    min-height: 100vh;
    padding: 0 0 4rem;
  }

  .home-header {
    padding: 5rem 0 3.5rem;
    max-width: 680px;
  }

  .home-eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6ee7b7;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .home-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: #f0f0f0;
    margin-bottom: 1.5rem;
  }

  .home-sub {
    font-size: 1.1rem;
    color: #777;
    line-height: 1.75;
    max-width: 52ch;
  }

  .home-author {
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: #555;
  }

  .home-author strong {
    color: #e8e8e8;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    border: 1px solid #1a1a1a;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2rem;
    border: 1px solid #1a1a1a;
    text-decoration: none;
    color: inherit;
    background: #0f0f0f;
    transition: background 0.2s;
    position: relative;
  }

  .post-card:hover {
    background: #131313;
  }

  .post-card:hover .card-cta {
    color: #6ee7b7;
  }

  .post-card--coming {
    opacity: 0.3;
    pointer-events: none;
  }

  .card-week {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6ee7b7;
    font-weight: 600;
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #e8e8e8;
    line-height: 1.3;
  }

  .coming-title {
    color: #444;
  }

  .card-desc {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
    flex: 1;
  }

  .card-cta {
    font-size: 0.85rem;
    color: #555;
    margin-top: 0.5rem;
    transition: color 0.2s;
  }

  @media (max-width: 600px) {
    .home-header {
      padding: 3rem 0 2rem;
    }
    .home-eyebrow {
      font-size: 0.7rem;
      letter-spacing: 0.08em;
    }
    .home-title {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }
  }
</style>
