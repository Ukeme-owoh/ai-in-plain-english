---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) => a.data.week - b.data.week);
const base = import.meta.env.BASE_URL;
---

<Base title="Home">
  <div class="home">

    <header class="home-header">
      <h1 class="home-title">Modern AI, explained.</h1>
      <p class="home-sub">
        One visual post a week. Transformers. Reasoning models. Agents. Evals.
        Written for curious people who want to understand AI without enrolling in a degree.
      </p>
      <p class="home-author">
        By <strong>Ukeme Owoh</strong>
        <a
          href="https://www.linkedin.com/in/ukemeowoh/"
          class="home-linkedin"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Ukeme Owoh on LinkedIn"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </p>
    </header>

    <section class="post-grid">
      {posts.map((post) => (
        <a href={`${base}/posts/${post.slug}`} class="post-card">
          <span class="card-week">Week {post.data.week}</span>
          <h2 class="card-title">{post.data.title}</h2>
          <p class="card-desc">{post.data.description}</p>
          <span class="card-cta">Read →</span>
        </a>
      ))}

      {Array.from({ length: Math.max(0, 12 - posts.length) }).map((_, i) => (
        <div class="post-card post-card--coming">
          <span class="card-week">Week {posts.length + i + 1}</span>
          <h2 class="card-title coming-title">Coming soon</h2>
        </div>
      ))}
    </section>

  </div>
</Base>

<style>
  /* Home page owns its own spacing — --gutter is the single source of truth */
  :global(body) {
    --gutter: clamp(1rem, 4vw, 2.5rem);
    padding-left: 0;
    padding-right: 0;
  }

  :global(main) {
    max-width: none;
    padding: 0;
  }

  /* Align the site nav left edge with the home title */
  :global(body > header) {
    max-width: none;
    margin: 0;
    padding: 2rem var(--gutter);
  }

  .home {
    min-height: 100vh;
    padding: 0 0 4rem;
  }

  /* Override the global `header` rule (720px centered, bottom border) */
  .home-header {
    max-width: none;
    margin: 0;
    border-bottom: none;
    padding: 2rem var(--gutter) 3rem;
  }

  .home-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: #f0f0f0;
    margin-bottom: 1.5rem;
  }

  .home-sub {
    font-size: 1.1rem;
    color: #777;
    line-height: 1.75;
  }

  .home-author {
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: #555;
  }

  .home-author strong {
    color: #e8e8e8;
  }

  .home-linkedin {
    display: inline-flex;
    align-items: center;
    margin-left: 0.4rem;
    color: #555;
    vertical-align: -3px;
    transition: color 0.2s;
  }

  .home-linkedin:hover {
    color: #6ee7b7;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    border: 1px solid #1a1a1a;
    margin-inline: var(--gutter);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 2rem;
    border: 1px solid #1a1a1a;
    text-decoration: none;
    color: inherit;
    background: #0f0f0f;
    transition: background 0.2s;
    position: relative;
  }

  .post-card:hover {
    background: #131313;
  }

  .post-card:hover .card-cta {
    color: #6ee7b7;
  }

  .post-card--coming {
    opacity: 0.3;
    pointer-events: none;
  }

  .card-week {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6ee7b7;
    font-weight: 600;
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #e8e8e8;
    line-height: 1.3;
  }

  .coming-title {
    color: #444;
  }

  .card-desc {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
    flex: 1;
  }

  .card-cta {
    font-size: 0.85rem;
    color: #555;
    margin-top: 0.5rem;
    transition: color 0.2s;
  }

  @media (max-width: 600px) {
    .home-header {
      padding: 1.5rem var(--gutter) 2rem;
    }
    .home-title {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }
  }
</style>
