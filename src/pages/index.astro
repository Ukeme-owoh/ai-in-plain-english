---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) => a.data.week - b.data.week);
const base = import.meta.env.BASE_URL;

const TABS = [
  { slug: 'tech', label: 'Tech' },
  { slug: 'strategy', label: 'Strategy' },
  { slug: 'policy', label: 'Policy' },
];

const techPosts = posts.filter((p) => p.data.category === 'tech');
const techPlaceholders = Math.max(0, 12 - techPosts.length);
const emptyPlaceholders = 6;
---

<Base title="Home">
  <script is:inline>
    (function () {
      var valid = ['tech', 'strategy', 'policy'];
      var params = new URLSearchParams(location.search);
      var t = params.get('tab');
      document.documentElement.dataset.activeTab = valid.indexOf(t) >= 0 ? t : 'tech';
    })();
  </script>

  <div class="home">

    <header class="home-header">
      <h1 class="home-title">Modern AI, explained.</h1>
      <p class="home-sub">
        One visual post a week. Transformers. Reasoning models. Agents. Evals.
        Written for curious people who want to understand AI.
      </p>
      <p class="home-author">
        By <strong>Ukeme Owoh</strong>
        <a
          href="https://www.linkedin.com/in/ukemeowoh/"
          class="home-linkedin"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Ukeme Owoh on LinkedIn"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </p>

      <nav class="home-tabs" aria-label="Article categories">
        {TABS.map((t) => (
          <a
            href={t.slug === 'tech' ? `${base}/` : `${base}/?tab=${t.slug}`}
            class="home-tab"
            data-tab={t.slug}
          >
            {t.label}
          </a>
        ))}
      </nav>
    </header>

    <section class="post-grid">
      {techPosts.map((post) => (
        <a
          href={`${base}/posts/${post.slug}`}
          class={`post-card theme-${post.data.theme ?? 'lavender'}`}
          data-category="tech"
        >
          <div class="card-preview">
            <div class="card-meta">
              <span class="card-status">
                <span class="card-dot"></span>
                {post.data.previewLabel ?? 'article.read()'}
              </span>
              <span class="card-week">Week {post.data.week}</span>
            </div>
            <div class="card-figure">
              <div class="card-icon-ring">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                  <rect x="2" y="9" width="6" height="6" rx="1.5" />
                  <rect x="9" y="9" width="6" height="6" rx="1.5" />
                  <rect x="16" y="9" width="6" height="6" rx="1.5" />
                </svg>
              </div>
              <span class="card-figure-label">{post.data.previewCaption ?? 'Article'}</span>
            </div>
          </div>
          <div class="card-body">
            <h2 class="card-title">{post.data.title}</h2>
            <p class="card-desc">{post.data.description}</p>
          </div>
        </a>
      ))}

      {Array.from({ length: techPlaceholders }).map((_, i) => (
        <div class="post-card post-card--coming" data-category="tech">
          <div class="card-preview">
            <div class="card-meta">
              <span class="card-week">Week {techPosts.length + i + 1}</span>
            </div>
            <div class="card-figure">
              <div class="card-icon-ring card-icon-ring--empty"></div>
            </div>
          </div>
          <div class="card-body">
            <h2 class="card-title coming-title">Coming soon</h2>
          </div>
        </div>
      ))}

      {Array.from({ length: emptyPlaceholders }).map((_, i) => (
        <div class="post-card post-card--coming" data-category="strategy">
          <div class="card-preview">
            <div class="card-figure">
              <div class="card-icon-ring card-icon-ring--empty"></div>
            </div>
          </div>
          <div class="card-body">
            <h2 class="card-title coming-title">Coming soon</h2>
          </div>
        </div>
      ))}

      {Array.from({ length: emptyPlaceholders }).map((_, i) => (
        <div class="post-card post-card--coming" data-category="policy">
          <div class="card-preview">
            <div class="card-figure">
              <div class="card-icon-ring card-icon-ring--empty"></div>
            </div>
          </div>
          <div class="card-body">
            <h2 class="card-title coming-title">Coming soon</h2>
          </div>
        </div>
      ))}
    </section>

  </div>
</Base>

<script is:inline>
  (function () {
    var valid = ['tech', 'strategy', 'policy'];

    function getTab() {
      var t = new URLSearchParams(location.search).get('tab');
      return valid.indexOf(t) >= 0 ? t : 'tech';
    }

    function applyTab(tab, push) {
      document.documentElement.dataset.activeTab = tab;
      if (push) {
        var url = new URL(location.pathname, location.origin);
        if (tab !== 'tech') url.searchParams.set('tab', tab);
        history.pushState({ tab: tab }, '', url);
      }
    }

    document.querySelectorAll('.home-tab').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        applyTab(el.dataset.tab, true);
      });
    });

    window.addEventListener('popstate', function () {
      applyTab(getTab(), false);
    });
  })();
</script>

<style>
  /* Home page owns its own spacing — --gutter is the single source of truth */
  :global(body) {
    --gutter: clamp(1rem, 4vw, 2.5rem);
    padding-left: 0;
    padding-right: 0;
  }

  :global(main) {
    max-width: none;
    padding: 0;
  }

  /* Align the site nav left edge with the home title */
  :global(body > header) {
    max-width: none;
    margin: 0;
    padding: 2rem var(--gutter);
  }

  .home {
    min-height: 100vh;
    padding: 0 0 4rem;
  }

  /* Override the global `header` rule (720px centered, bottom border) */
  .home-header {
    max-width: none;
    margin: 0;
    border-bottom: none;
    padding: 2rem var(--gutter) 2rem;
  }

  .home-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: #f0f0f0;
    margin-bottom: 1.5rem;
  }

  .home-sub {
    font-size: 1.1rem;
    color: #777;
    line-height: 1.75;
  }

  .home-author {
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: #555;
  }

  .home-author strong {
    color: #e8e8e8;
  }

  .home-linkedin {
    display: inline-flex;
    align-items: center;
    margin-left: 0.4rem;
    color: #555;
    vertical-align: -3px;
    transition: color 0.2s;
  }

  .home-linkedin:hover {
    color: #6ee7b7;
  }

  .home-tabs {
    display: flex;
    gap: 1.75rem;
    margin-top: 2rem;
  }

  .home-tab {
    color: #777;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    min-width: 9rem;
    text-align: center;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .home-tab:hover {
    color: #6ee7b7;
  }

  /* Active tab — driven by html[data-active-tab] */
  :global(html[data-active-tab='tech']) .home-tab[data-tab='tech'],
  :global(html[data-active-tab='strategy']) .home-tab[data-tab='strategy'],
  :global(html[data-active-tab='policy']) .home-tab[data-tab='policy'] {
    color: #6ee7b7;
    border-bottom-color: #6ee7b7;
  }

  /* Hide cards that don't match the active tab */
  :global(html[data-active-tab='tech']) .post-card:not([data-category='tech']),
  :global(html[data-active-tab='strategy']) .post-card:not([data-category='strategy']),
  :global(html[data-active-tab='policy']) .post-card:not([data-category='policy']) {
    display: none;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-inline: var(--gutter);
  }

  /* Pastel theme palette */
  .theme-lavender { --theme-color: #c4b5fd; }
  .theme-sky      { --theme-color: #7dd3fc; }
  .theme-coral    { --theme-color: #fda4af; }
  .theme-amber    { --theme-color: #fcd34d; }
  .theme-mint     { --theme-color: #86efac; }
  .theme-magenta  { --theme-color: #f0abfc; }

  .post-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #1a1a1a;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: #0f0f0f;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
  }

  .post-card:hover {
    border-color: color-mix(in srgb, var(--theme-color, #333) 40%, #1a1a1a);
    transform: translateY(-2px);
  }

  .post-card--coming {
    opacity: 0.45;
    pointer-events: none;
  }

  /* Top zone — themed preview */
  .card-preview {
    position: relative;
    min-height: 200px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    background-color: color-mix(in srgb, var(--theme-color, #2a2a2a) 5%, #0f0f0f);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 22px 22px;
    border-bottom: 1px solid #1a1a1a;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.72rem;
  }

  .card-status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: 'Fira Code', ui-monospace, SFMono-Regular, monospace;
    color: var(--theme-color, #888);
  }

  .card-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--theme-color, #888);
    box-shadow: 0 0 6px var(--theme-color, transparent);
  }

  .card-week {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #555;
    font-weight: 600;
  }

  .card-figure {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
  }

  .card-icon-ring {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    border: 2px solid var(--theme-color, #2a2a2a);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--theme-color, transparent) 18%, transparent),
      0 0 22px color-mix(in srgb, var(--theme-color, transparent) 50%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--theme-color, #555);
  }

  .card-icon-ring--empty {
    border-color: #2a2a2a;
    box-shadow: none;
    background: rgba(0, 0, 0, 0.25);
  }

  .card-figure-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: #e8e8e8;
    letter-spacing: 0.01em;
  }

  /* Bottom zone — content */
  .card-body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #e8e8e8;
    line-height: 1.3;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .coming-title {
    color: #444;
  }

  .card-desc {
    font-size: 0.88rem;
    color: #777;
    line-height: 1.55;
  }

  @media (max-width: 600px) {
    .home-header {
      padding: 1.5rem var(--gutter) 1.5rem;
    }
    .home-title {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }

    /* Tabs flex to share viewport equally instead of fixed 9rem */
    .home-tabs {
      gap: 0.5rem;
    }
    .home-tab {
      min-width: 0;
      flex: 1 1 0;
      font-size: 0.85rem;
      padding-bottom: 0.4rem;
    }

    /* Force one column so cards never exceed viewport width */
    .post-grid {
      grid-template-columns: 1fr;
    }
    .card-title {
      font-size: 1rem;
    }
    .card-meta {
      font-size: 0.65rem;
    }
  }
</style>
