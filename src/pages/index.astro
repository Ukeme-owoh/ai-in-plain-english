---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => a.data.week - b.data.week
);

const base = import.meta.env.BASE_URL;
---

<Base title="Home">
  <section class="hero">
    <h1>Modern AI, explained without the PhD.</h1>
    <p>
      Most AI writing either oversimplifies or overwhelms readers. This site finds the middle.
      One visual post a week. Transformers. Reasoning models. Agents. Evals.
      Written for curious people who want to understand AI without enrolling in a degree.
    </p>
  </section>

  <section class="posts">
    <h2>All Posts</h2>
    {posts.length === 0 && <p>First post coming soon.</p>}
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`${base}/posts/${post.slug}`}>
            <span class="week">Week {post.data.week}</span>
            <span class="title">{post.data.title}</span>
            <span class="description">{post.data.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
